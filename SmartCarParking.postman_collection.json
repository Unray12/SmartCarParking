{
  "info": {
    "_postman_id": "5c2f0a10-1b2c-4d3e-9f00-a1b2c3d4e5f6",
    "name": "SmartCarParking API (v1)",
    "description": "Toàn bộ API SmartCarParking. Chạy Auth > Login trước để lưu {{token}}; request khác tự dùng Bearer. Sửa {{baseUrl}} nếu backend khác host/cổng.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8010"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "username",
      "value": "admin"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (lưu token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Đăng nhập, tự lưu access_token vào biến {{token}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j && j.access_token) {",
                  "  pm.collectionVariables.set('token', j.access_token);",
                  "  pm.collectionVariables.set('username', j.username);",
                  "}",
                  "pm.test('login 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"admin\",\n  \"new_password\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Reset Password (public)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"new_password\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          }
        }
      ]
    },
