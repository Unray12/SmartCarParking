# Copy file này thành `.env` (cùng cấp docker-compose.yml) rồi chỉnh lại.
# docker-compose sẽ tự đọc .env này để build/run.

# ==== PostgreSQL ====
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=smartparking

# ==== Đường dẫn TRÊN MÁY HOST để lưu dữ liệu persist ====
# Có thể để tương đối (./data/...) hoặc tuyệt đối (D:/smartparking-data/... , /srv/smartparking/...).
# Khi build/deploy lại container mới, các thư mục này vẫn giữ nguyên dữ liệu cũ.
POSTGRES_DATA_DIR=./data/postgres
SNAPSHOTS_DIR=./data/snapshots
MODELS_DIR=./data/models
LOGS_DIR=./data/logs

# ==== App secrets (bắt buộc đổi khi lên production) ====
JWT_SECRET=CHANGE_ME_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
CORS_ORIGINS=*

# ==== RFID USB reader (chỉ hoạt động khi chạy trên Linux host có gắn passthrough thiết bị) ====
RFID_USB_ENABLED=false
RFID_USB_PORT=/dev/ttyUSB0

# ==== Cổng public trên host ====
BACKEND_PORT=8010
FRONTEND_PORT=5173
