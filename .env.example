# Copy file này thành `.env` (cùng cấp docker-compose.yml) rồi chỉnh lại.
# File .env này được Docker Compose dùng cho 2 việc:
# 1) Thay ${VAR} trong docker-compose.yml (build/run container, đường dẫn volume...)
# 2) Nạp trực tiếp vào biến môi trường của container backend qua `env_file:`
#    -> app đọc thẳng từ đây, KHÔNG dùng backend/.env khi chạy Docker.

# ==== PostgreSQL (container db) ====
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=smartparking

# ==== Đường dẫn TRÊN MÁY HOST để lưu dữ liệu persist - TẤT CẢ gom vào backend/data/ ====
# (có thể đổi sang path tuyệt đối, ví dụ D:/smartparking-data/...).
# Khi build/deploy lại container mới, các thư mục này vẫn giữ nguyên dữ liệu cũ.
POSTGRES_DATA_DIR=./backend/data/postgres
LOGS_DIR=./backend/data/logs
# snapshots_store/models_store dùng ĐÚNG tên thư mục mà backend đã dùng sẵn (chỉ
# khác là nằm trong data/ để gom hết 1 chỗ) -> đồng bộ với AI_MODELS_DIR/
# SNAPSHOT_STORE_DIR ở dưới, và cả backend/.env dùng khi chạy không-Docker.
SNAPSHOTS_DIR=./backend/data/snapshots_store
MODELS_DIR=./backend/data/models_store

# ==== Cổng public trên host ====
BACKEND_PORT=8010
FRONTEND_PORT=5173
POSTGRES_PORT=5432

# ================================================================
# ==== Toàn bộ config app (đối chiếu backend/app/core/config.py) ====
# Nạp thẳng vào container backend qua env_file, KHÔNG dùng backend/.env khi build Docker.
# ================================================================
APP_NAME=Smart Parking Backend

# Seed admin lần đầu (sau đó đổi/reset qua UI, lưu trong DB bảng admin_users)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT (BẮT BUỘC đổi JWT_SECRET ở production)
JWT_SECRET=CHANGE_ME_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
RFID_LINK_WINDOW_SECONDS=30
CORS_ORIGINS=*
PLATE_RECOGNIZER=

# Phí gửi xe & sức chứa
PARKING_CURRENCY=đ
PARKING_FEE_BASE=0
PARKING_FEE_PER_BLOCK=5000
PARKING_FEE_BLOCK_MINUTES=60
PARKING_FREE_MINUTES=15
PARKING_DEFAULT_CAPACITY=50

STREAM_TARGET_FPS=25
STREAM_JPEG_QUALITY=82
STREAM_MAX_WIDTH=1280
STREAM_CAPTURE_SKIP_GRABS=0
STREAM_WS_TARGET_FPS=25
STREAM_RTSP_TRANSPORT=tcp
STREAM_FFMPEG_CAPTURE_OPTIONS=fflags;nobuffer|flags;low_delay|reorder_queue_size;0|max_delay;500000
STREAM_INFER_EVERY_N_FRAMES=0
STREAM_ENABLE_INFERENCE=false
STREAM_PLATE_DEDUPE_SECONDS=8

# Tên 2 thư mục này PHẢI khớp với volume mount trong docker-compose.yml
# (SNAPSHOTS_DIR/MODELS_DIR phía trên) - path tương đối theo backend root, resolve
# đúng vào backend/data/snapshots_store và backend/data/models_store.
AI_MODELS_DIR=data/models_store
SNAPSHOT_STORE_DIR=data/snapshots_store

# RFID USB - chỉ chạy được nếu container có passthrough thiết bị (xem `devices:`
# trong docker-compose.yml, chỉ hoạt động trên Linux host có gắn đầu đọc thật).
RFID_USB_PORT=/dev/ttyUSB0
RFID_USB_BAUDRATE=115200
RFID_USB_QUEUE_MAX_SIZE=500
RFID_USB_ENABLED=false
