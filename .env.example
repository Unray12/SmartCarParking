# Copy file này thành `.env` (cùng cấp docker-compose.yml) rồi chỉnh lại.
# File .env này được Docker Compose dùng cho 2 việc:
# 1) Thay ${VAR} trong docker-compose.yml (build/run container, đường dẫn volume...)
# 2) Nạp trực tiếp vào biến môi trường của container backend qua `env_file:`
#    -> app đọc thẳng từ đây, KHÔNG dùng backend/.env khi chạy Docker.

# ==== PostgreSQL (container db) ====
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=smartparking

# ==== Đường dẫn TRÊN MÁY HOST để lưu dữ liệu persist - TẤT CẢ gom vào backend/data/ ====
# (có thể đổi sang path tuyệt đối, ví dụ D:/smartparking-data/...).
# Khi build/deploy lại container mới, các thư mục này vẫn giữ nguyên dữ liệu cũ.
POSTGRES_DATA_DIR=./backend/data/postgres
LOGS_DIR=./backend/data/logs
# snapshots_store/models_store dùng ĐÚNG tên thư mục mà backend đã dùng sẵn (chỉ
# khác là nằm trong data/ để gom hết 1 chỗ) -> đồng bộ với AI_MODELS_DIR/
# SNAPSHOT_STORE_DIR ở dưới, và cả backend/.env dùng khi chạy không-Docker.
SNAPSHOTS_DIR=./backend/data/snapshots_store
MODELS_DIR=./backend/data/models_store

# ==== Cổng public trên host ====
BACKEND_PORT=8010
FRONTEND_PORT=5173
POSTGRES_PORT=5432

# ================================================================
# ==== Toàn bộ config app (đối chiếu backend/app/core/config.py) ====
# Nạp thẳng vào container backend qua env_file, KHÔNG dùng backend/.env khi build Docker.
# ================================================================
APP_NAME=Smart Parking Backend

# Seed admin lần đầu (sau đó đổi/reset qua UI, lưu trong DB bảng admin_users)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT (BẮT BUỘC đổi JWT_SECRET ở production)
JWT_SECRET=CHANGE_ME_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Token RIÊNG, ngắn hạn để mở 1 file snapshot cụ thể (nhúng sẵn trong image_url trả về) -
# KHÁC JWT đăng nhập ở trên. Ảnh <img src> phải mang token qua URL (không gắn được header),
# dùng token hạn ngắn + khoá theo đúng 1 file để lộ URL ảnh không tương đương lộ JWT toàn quyền.
SNAPSHOT_TOKEN_TTL_SECONDS=600
RFID_LINK_WINDOW_SECONDS=30
CORS_ORIGINS=*
# ANPR YOLOv5 2 giai đoạn (detect biển + detect ký tự, chạy ONNX). Chỉ thực sự
# chạy khi bãi xe có ai_enabled=True. Cần 2 file .onnx trong MODELS_DIR ở trên
# (PLATE_DETECTOR_MODEL/PLATE_OCR_MODEL) - thiếu file thì tự fallback PaddleOCR/Dummy.
PLATE_RECOGNIZER=app.services.yolo_onnx_plate_recognizer:YoloOnnxPlateRecognizer
PLATE_DETECTOR_MODEL=LP_detector.onnx
PLATE_OCR_MODEL=LP_ocr.onnx
PLATE_DETECTOR_IMGSZ=640
PLATE_DETECTOR_CONF=0.5
PLATE_OCR_CONF=0.6
# 1 camera = 1 làn xe -> chỉ OCR N box tự tin nhất theo confidence (bỏ box thừa/nhiễu, đã
# đo thực tế 1 frame ra tới 6 box). KHÔNG lọc theo kích thước pixel - biển ở xa vẫn hợp lệ.
PLATE_DETECTOR_MAX_BOXES=2

# Phí gửi xe & sức chứa
PARKING_CURRENCY=đ
PARKING_FEE_BASE=0
PARKING_FEE_PER_BLOCK=5000
PARKING_FEE_BLOCK_MINUTES=60
PARKING_FREE_MINUTES=15
PARKING_DEFAULT_CAPACITY=50

STREAM_TARGET_FPS=25
STREAM_JPEG_QUALITY=82
STREAM_MAX_WIDTH=1280
# >0: grab() thêm N lần rồi mới retrieve() để chủ động vứt frame cũ tồn trong buffer,
# luôn hiển thị frame mới nhất. CHỈ an toàn với RTSP camera thật đẩy liên tục - đã tự
# test: bật với nguồn HTTP/MJPEG tốc độ thấp làm MẤT HẲN frame (grab() thừa bị fail).
# Giữ 0 mặc định; chỉ tăng nếu chắc chắn dùng RTSP thật và vẫn còn trễ sau khi giảm max_delay.
STREAM_CAPTURE_SKIP_GRABS=0
STREAM_WS_TARGET_FPS=25
STREAM_RTSP_TRANSPORT=tcp
# max_delay thấp (100ms) để FFmpeg không giữ gói tin chờ ghép nối trước khi trả frame -
# đổi lấy rủi ro giật hình nhẹ trên mạng kém ổn định. Key KHÔNG được lặp lại (OpenCV parse
# thành av_dict, key trùng bị ghi đè chứ không cộng dồn) - 2 cờ của fflags phải gộp bằng "+".
STREAM_FFMPEG_CAPTURE_OPTIONS=fflags;nobuffer+discardcorrupt|flags;low_delay|reorder_queue_size;0|max_delay;100000
STREAM_INFER_EVERY_N_FRAMES=0
STREAM_ENABLE_INFERENCE=false
STREAM_PLATE_DEDUPE_SECONDS=8
STREAM_PERIODIC_RECONNECT_SECONDS=1800

# ==== WebRTC qua MediaMTX (RTSP -> MediaMTX -> WebRTC -> browser, JPEG-WS làm fallback) ====
STREAM_WEBRTC_ENABLED=true
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTSP_BASE=rtsp://mediamtx:8554
MEDIAMTX_WEBRTC_PUBLIC_BASE=
# ĐẶT bằng IP LAN thật của máy chạy Docker để browser máy khác kết nối được WebRTC.
MEDIAMTX_WEBRTC_HOST=127.0.0.1
STREAM_INTERNAL_TOKEN=CHANGE_ME_internal_stream_token

# Tên 2 thư mục này PHẢI khớp với volume mount trong docker-compose.yml
# (SNAPSHOTS_DIR/MODELS_DIR phía trên) - path tương đối theo backend root, resolve
# đúng vào backend/data/snapshots_store và backend/data/models_store.
AI_MODELS_DIR=data/models_store
SNAPSHOT_STORE_DIR=data/snapshots_store

# RFID USB - chỉ chạy được nếu container có passthrough thiết bị (xem `devices:`
# trong docker-compose.yml, chỉ hoạt động trên Linux host có gắn đầu đọc thật).
# Board dùng USB native (ESP32-S3/YoloUNO...) thường lên /dev/ttyACM0; board
# qua chip cầu USB-serial (CP2102/CH340...) thường lên /dev/ttyUSB0 - kiểm tra
# lại bằng `ls /dev/tty*` hoặc `dmesg | tail` ngay sau khi cắm dây để biết đúng path.
RFID_USB_PORT=/dev/ttyACM0
RFID_USB_BAUDRATE=115200
RFID_USB_QUEUE_MAX_SIZE=500
RFID_USB_ENABLED=false
